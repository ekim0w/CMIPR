import math

# =========================
# ФУНКЦИЯ 1
# =========================

def f1(x):
    return x**3 - 3*x**2 + 9*x + 2

def df1(x):
    return 3*x**2 - 6*x + 9


# =========================
# ФУНКЦИЯ 2
# =========================

def f2(x):
    return math.log10(x) - 7/(2*x + 6)

def df2(x):
    return 1/(x * math.log(10)) + 14/((2*x + 6)**2)


# =========================
# МЕТОД НЬЮТОНА
# =========================

def newton(f, df, x0, m, eps=1e-6, max_iter=100):
    x = x0
    i = 0

    print(f"{'i':<3} {'x_i':<12} {'f(x_i)':<12} {'f\'(x_i)':<12} {'|f(x_i)|/m':<12}")
    print("-"*60)

    while abs(f(x))/m > eps and i < max_iter:
        print(f"{i:<3} {x:<12.8f} {f(x):<12.8f} {df(x):<12.8f} {abs(f(x))/m:<12.8f}")
        
        if df(x) == 0:
            print("Производная равна нулю.")
            return
        
        x = x - f(x)/df(x)
        i += 1

    print(f"{i:<3} {x:<12.8f} {f(x):<12.8f} {df(x):<12.8f} {abs(f(x))/m:<12.8f}  ε")
    print("Корень:", round(x, 8))
    print("\n")


# =========================
# ЗАПУСК ДВУХ ФУНКЦИЙ
# =========================

print("Первая функция:")
newton(f1, df1, x0=-1.0, m=6.0)

print("Вторая функция:")
newton(f2, df2, x0=1.0, m=0.5)

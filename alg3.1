import math

# =========================
# ВТОРАЯ ФУНКЦИЯ
# =========================

def f(x):
    return math.log10(x) - 7/(2*x + 6)

def df(x):
    return 1/(x * math.log(10)) + 14/((2*x + 6)**2)


# =========================
# МЕТОД НЬЮТОНА
# =========================

x = 1.0          # начальное приближение
eps = 1e-6
m = 0.5          # нижняя граница |f'(x)| (подбирается по интервалу)
max_iter = 100

print(f"{'i':<3} {'x_i':<12} {'f(x_i)':<12} {'f\'(x_i)':<12} {'|f(x_i)|/m':<12}")
print("-"*60)

i = 0

while abs(f(x))/m > eps and i < max_iter:
    print(f"{i:<3} {x:<12.8f} {f(x):<12.8f} {df(x):<12.8f} {abs(f(x))/m:<12.8f}")
    
    if df(x) == 0:
        print("Производная равна нулю.")
        break
    
    x = x - f(x)/df(x)
    i += 1

print(f"{i:<3} {x:<12.8f} {f(x):<12.8f} {df(x):<12.8f} {abs(f(x))/m:<12.8f}  ε")
print("\nКорень:", round(x, 8))
